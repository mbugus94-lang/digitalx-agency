PORT=3000
NODE_ENV=development

# API Key (for admin access to leads)
API_KEY=your-secure-api-key-here

# JWT Secret for session tokens
JWT_SECRET=your-jwt-secret-here

# Encryption key for lead data (32 bytes hex)
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Email Configuration (for lead notifications)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your-email@ethereal.email
SMTP_PASS=your-email-password
EMAIL_FROM=noreply@digitalx-agency.com
NOTIFICATION_EMAIL=hello@digitalx-agency.com

# Meta Pixel ID (for Facebook tracking)
META_PIXEL_ID=YOUR_PIXEL_ID_HERE

# GA4 Measurement ID
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
